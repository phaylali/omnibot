# === Discord Bot Credentials ===
# Get these from https://discord.com/developers/applications

# Your bot's application ID
APP_ID=<YOUR_APP_ID>

# Your bot's secret token (keep this private!)
DISCORD_TOKEN=<YOUR_BOT_TOKEN>

# Your bot's public key for verifying interactions
PUBLIC_KEY=<YOUR_PUBLIC_KEY>

# (Optional) Specific server/guild ID for development — speeds up command registration
# GUILD_ID=<YOUR_GUILD_ID>

# (Optional) Comma-separated list of user IDs with bot owner privileges
# OWNER_IDS=<YOUR_USER_ID>
